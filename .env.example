# LLM diagnostics: set CYMAS_MODEL and exactly one provider API key below.
# LiteLLM supports many providers; see https://docs.litellm.ai/docs/providers

CYMAS_MODEL=gemini/gemini-2.5-flash-lite

# Google (Gemini) — use with gemini/... models (GOOGLE_API_KEY or GEMINI_API_KEY)
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Anthropic (Claude) — use with anthropic/... models
ANTHROPIC_API_KEY=

# OpenAI (GPT) — use with openai/... models
OPENAI_API_KEY=

# Azure OpenAI — use with azure/... models
AZURE_API_KEY=
AZURE_API_BASE=

# Groq — use with groq/... models
GROQ_API_KEY=

# Together — use with together_ai/... models
TOGETHER_API_KEY=

# Cohere — use with cohere/... models
COHERE_API_KEY=

# Mistral — use with mistral/... models
MISTRAL_API_KEY=

# OpenRouter — use with openrouter/... models (many backends)
OPENROUTER_API_KEY=
